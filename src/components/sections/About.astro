---
import portrait from "../../assets/images/portrait.png";
---
<section id="colorlib-about">
  <div class="container">
    <div class="row text-center">
      <h2 class="bold">About Me</h2>
    </div>
    <div class="row">
      <div class="col-md-5 animate-box">
        <img class="img-responsive about-img" src={portrait.src} alt="Brian Balili" />
      </div>
      <div class="col-md-6 col-md-push-1 animate-box">
        <div class="about-desc">
          <div class="about-title">
            <div class="item">
              <h2><span>Brian Balili</span></h2>
            </div>
            <div class="item">
              <h2><span>Computer Engineer</span></h2>
            </div>
          </div>
          <div class="desc">
            <div class="rotate">
              <h2 class="heading">About</h2>
            </div>
            <p>
              Recent Computer Engineering graduate with experience building software solutions,
              integrating hardware systems, and supporting end users in fast-paced
              environments. I have worked on full-stack web applications using Python,
              Vue.js, and PostgreSQL, and led an IoT and computer vision thesis project.
              I am comfortable moving between application development, databases,
              troubleshooting, and system integration, and I am known for learning new
              tools quickly and explaining technical ideas clearly.
            </p>

            <p class="colorlib-social-icons">
              <a href="https://linkedin.com/in/brian-balili" target="_blank" rel="noreferrer">
                <i class="icon-linkedin"></i>
              </a>
              <a href="https://github.com/eautify" target="_blank" rel="noreferrer">
                <i class="icon-github"></i>
              </a>
            </p>

            <div class="about-buttons">
              <p>
                <a href="/assets/Resume.pdf" target="_blank" rel="noreferrer" class="btn btn-primary btn-outline">
                  Download Resume
                </a>
              </p>
              <p><a href="#footer" class="btn btn-primary btn-outline">Contact Me!</a></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
