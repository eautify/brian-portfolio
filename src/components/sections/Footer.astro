---
const year = new Date().getFullYear();
---
<footer>
  <div id="footer">
    <div class="container">
      <div class="row">
        <div class="col-md-4 col-sm-12 footer-widget">
          <h3 class="footer-title">About This Page</h3>
          <p>A personal portfolio showcasing my work in software development, embedded systems, and technical problem-solving.</p>
          <p class="footer-social-icons">
            <a href="https://linkedin.com/in/brian-balili" target="_blank" rel="noreferrer"><i class="icon-linkedin"></i></a>
            <a href="https://github.com/eautify" target="_blank" rel="noreferrer"><i class="icon-github"></i></a>
          </p>
        </div>

        <div class="col-md-4 col-sm-6 footer-widget">
          <h3 class="footer-title">Quick Links</h3>
          <ul class="footer-links">
            <li><a href="#colorlib-about">About</a></li>
            <li><a href="#colorlib-services">Skills</a></li>
            <li><a href="#colorlib-work">Projects</a></li>
            <li><a href="#colorlib-experience">Experience</a></li>
            <li><a href="#colorlib-education">Education</a></li>
          </ul>
        </div>

        <div class="col-md-4 col-sm-6 footer-widget">
          <h3 class="footer-title">Contact Info</h3>
          <ul class="footer-contact-info">
            <li><i class="icon-mail5"></i> <a href="mailto:brian.balili3@gmail.com">brian.balili3@gmail.com</a></li>
            <li><i class="icon-phone4"></i> <span>+63 (938) 976-3824</span></li>
            <li><i class="icon-map5"></i> <span>Pinagbuhatan, Pasig City</span></li>
          </ul>
        </div>
      </div>

      <div class="row">
        <div class="col-md-12 text-center">
          <p class="copyright-text">
            &copy; Copyright &copy;{year} All rights reserved
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    display: block;
    width: 100%;
  }

  #footer {
    padding: 6em 0 2em 0;
    background: #fff;
    border-top: 1px solid #f0f0f0;
    color: #808080;
  }

  #footer p:last-child {
    margin-bottom: 0;
  }

  .footer-widget {
    margin-bottom: 40px;
  }

  .footer-title {
    font-size: 20px;
    font-weight: 700;
    font-family: "Karla", Arial, sans-serif;
    margin-bottom: 25px;
    color: #000;
  }

  .footer-widget p {
    color: #808080;
  }

  .footer-social-icons {
    margin-top: 20px;
  }

  .footer-social-icons a {
    color: #a0a0a0;
    margin-right: 15px;
    font-size: 24px;
    transition: color 0.3s ease;
  }

  .footer-social-icons a:hover {
    color: #ca82f8;
  }

  .footer-links {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .footer-links li {
    margin-bottom: 10px;
  }

  .footer-links a {
    color: #808080;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: #ca82f8;
    text-decoration: underline;
  }

  .footer-contact-info {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .footer-contact-info li {
    display: flex;
    align-items: flex-start;
    margin-bottom: 15px;
  }

  .footer-contact-info i {
    font-size: 20px;
    margin-right: 15px;
    color: #ca82f8;
    margin-top: 5px;
  }

  .footer-contact-info a,
  .footer-contact-info span {
    color: #808080;
    margin: 0;
  }

  .footer-contact-info a:hover {
    color: #ca82f8;
  }

  .copyright-text {
    margin-top: 4em;
    border-top: 1px solid #f0f0f0;
    padding-top: 2em;
    color: #a0a0a0;
    font-size: 14px;
  }
</style>
